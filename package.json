{
  "name": "rxterm",
  "version": "1.0.0",
  "description": "AI-powered hacker terminal for Windows",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite renderer --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "build:backend": "python -m pip install pyinstaller && python -m PyInstaller --noconfirm --onefile --name backend backend/main.py --distpath backend/dist --workpath backend/build --specpath backend",
    "build": "npm run build:backend && vite build renderer && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-attach": "^0.11.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-search": "^0.15.0",
    "gsap": "^3.12.5",
    "animejs": "^3.2.2",
    "@barba/core": "^2.9.7",
    "zustand": "^4.5.4",
    "recharts": "^2.12.7",
    "electron-log": "^5.1.7",
    "@phosphor-icons/react": "^2.1.7"
  },
  "devDependencies": {
    "vite": "^5.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "directories": {
      "output": "release"
    },
    "appId": "com.rxterm.app",
    "productName": "RXTerm",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "extraResources": [{ "from": "backend/dist/", "to": "backend/" }],
    "files": ["renderer/dist/**", "electron/**", "assets/icon.png"],
    "asarUnpack": ["renderer/dist/**"]
  }
}
